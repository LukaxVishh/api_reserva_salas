meta {
  name: 02_Buscar por ID
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/salas/{{salaAtivaId}}
  body: none
  auth: none
}

vars:pre-request {
  baseUrl: http://localhost:8080
  salaAtivaId: 1
}

tests {
  test("status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("body tem id", function() {
    expect(res.getBody()).to.have.property("id");
  });
}
